# EP-PEG AI Analysis Engine
# Fill in ONE of the following API keys to enable AI-powered PEG analysis reports

# Option 1: Anthropic Claude API (recommended)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Optional: Use a custom base URL (e.g., proxy or compatible provider)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: Override model name (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Option 2: OpenAI API
# OPENAI_API_KEY=sk-xxxxx

# Optional: Override base URL + model to use any OpenAI-compatible provider
# (DeepSeek / Qwen / GLM / Kimi / OpenRouter / Ollama ...). The OpenAI path is
# used whenever ANTHROPIC_API_KEY is NOT set.
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_MODEL=gpt-4o

# Example — DeepSeek (OpenAI-compatible):
# OPENAI_API_KEY=sk-your-deepseek-key
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_MODEL=deepseek-chat
